    ...spaces(1),

    h3('TC-G-11  Device Auto-Save Verification'),
    testTable([
      [1,'Add a document, checklist, and timer','3 items added'],
      [2,'Look at bottom of Dashboard','Green pill: "Saved to device X seconds ago"'],
