      [7,'Your custom step appears at the bottom of the list','It has a checkbox just like the built-in steps'],
      [8,'Try to add a second checklist','Blocked — limit popup appears'],
    ]),
    ...spaces(1),

    h3('TC-G-07  Adding a Timer (Counter) — All Types'),
    note('⏱️', 'Timers count how many days you have used out of a legal maximum. For example, OPT allows 90 days of unemployment — this timer tracks how many days you have used.'),
    ...spaces(1),
    testTable([
      [1,'Go to Timers tab','Empty screen with Add Timer button'],
      [2,'Click Add Timer','A picker shows 7 types: OPT Unemployment (90d), STEM OPT Unemployment (150d), H-1B Grace Period (60d), F-1 Grace Period (60d), B-1/B-2 Visitor Stay (180d), Days in US Tax Year (183d), J-1 Grace Period (30d)'],
      [3,'Pick "OPT Unemployment Days"','Timer card appears: 0/90 days used. Progress bar is empty.'],
      [4,'Click the Start button','Button changes to "Pause". Status line says "● Auto-tracking daily".'],
      [5,'Click the + button on the timer card','Days used goes up by 1'],
      [6,'Click the − button','Days used goes down by 1'],
      [7,'Click "Pause"','Button changes to "Resume". Status says "○ Paused — days while paused not counted"'],
      [8,'Click "Resume"','Button changes to "Pause" again. Tracking restarts.'],
      [9,'Try to add a second timer','Blocked — limit popup'],
    ]),
    ...spaces(1),

    h3('TC-G-08  Family Tab — Blocked for Guests'),
    testTable([
      [1,'Go to Family tab','Empty screen'],
      [2,'Click Add Family Member (or + button)','Popup: "Create a free account first". NO family member form appears.'],
      [3,'Close the popup','Back to empty Family screen. Nothing happened.'],
    ]),
    ...spaces(1),

    h3('TC-G-09  Search'),
    testTable([
      [1,'Click the 🔍 search icon in the top bar','Search modal opens with a text field'],
      [2,'Type "pass" (if you have a Passport doc)','Passport document appears in results immediately'],
      [3,'Type "opt" (if you have OPT timer)','OPT Unemployment timer appears in results'],
      [4,'Type "uscis"','Government links section shows USCIS.gov link'],
      [5,'Type "xyz999notreal"','Results are empty. App does not crash.'],
      [6,'Click on any result','App navigates to that screen/item'],
      [7,'Press Escape or click X','Search modal closes'],
    ]),
    ...spaces(1),

    h3('TC-G-10  Help Screen and Government Links'),
    testTable([
      [1,'Click the Help tab (? icon or "Help" in navigation)','Help screen opens with FAQ sections'],
      [2,'Click on any FAQ question','Answer expands below the question'],
      [3,'Scroll down to "Government Resources" section','You see links: USCIS, CBP I-94, Study in the States, State Dept, IRS International'],
      [4,'Click any government link','Link opens in a new browser tab on the correct .gov website'],
