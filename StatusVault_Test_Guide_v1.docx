      [1,'Open a fresh incognito window → go to statusvault.org','Welcome screen appears'],
      [2,'Click "Create Free Account"','Login screen appears'],
      [3,'Enter your email address','Email field accepts it'],
      [4,'Click "Send Magic Link"','Success message: "Check your email for a login link"'],
      [5,'Open your email inbox','Email from StatusVault with a clickable link'],
      [6,'Click the link in the email','Browser opens statusvault.org. You are logged in automatically.'],
      [7,'Look at the sidebar/top bar','FREE badge visible. NOT "Guest mode".'],
      [8,'Wait 2 seconds and look at the bottom of Dashboard','Auto-save pill still shows — data is saved locally AND you are logged in'],
