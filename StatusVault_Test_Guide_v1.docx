const {
  Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
  HeadingLevel, AlignmentType, BorderStyle, WidthType, ShadingType,
  LevelFormat, Footer,
} = require('docx');
const fs = require('fs');

const C = {
  navy:'1E3A5F', purple:'4F46E5', green:'166534', greenBg:'DCFCE7',
  amber:'92400E', amberBg:'FEF3C7', blue:'1E40AF', blueBg:'DBEAFE',
  red:'991B1B', redBg:'FEE2E2', gray:'374151', grayBg:'F9FAFB',
  lightGray:'E5E7EB', white:'FFFFFF', teal:'0F766E', tealBg:'CCFBF1',
  orange:'9A3412', orangeBg:'FFEDD5',
};
const b1 = { style:BorderStyle.SINGLE, size:1, color:C.lightGray };
const bord = { top:b1, bottom:b1, left:b1, right:b1 };
const noB = { style:BorderStyle.NONE, size:0, color:'FFFFFF' };
const noBord = { top:noB, bottom:noB, left:noB, right:noB };

const sp = (b=60,a=60)=>({ before:b, after:a });
const font = 'Arial';

const h1 = t => new Paragraph({ heading:HeadingLevel.HEADING_1, spacing:sp(360,160),
  children:[new TextRun({text:t, bold:true, size:36, color:C.navy, font})] });
const h2 = t => new Paragraph({ heading:HeadingLevel.HEADING_2, spacing:sp(280,120),
  children:[new TextRun({text:t, bold:true, size:28, color:C.purple, font})] });
const h3 = t => new Paragraph({ heading:HeadingLevel.HEADING_3, spacing:sp(200,80),
  children:[new TextRun({text:t, bold:true, size:24, color:C.navy, font})] });
const body = (t,opts={}) => new Paragraph({ spacing:sp(60,60),
  children:[new TextRun({text:t, size:22, color:C.gray, font, ...opts})] });
const spaces = (n=1) => Array.from({length:n}, ()=>
  new Paragraph({spacing:sp(0,0), children:[new TextRun({text:''})]}));
const divider = () => new Paragraph({ spacing:sp(160,160),
  border:{ bottom:{style:BorderStyle.SINGLE, size:4, color:C.lightGray} },
  children:[new TextRun({text:''})] });

const note = (emoji, text, bg=C.blueBg, col=C.blue) => new Table({
  width:{size:9360, type:WidthType.DXA}, columnWidths:[9360],
  rows:[new TableRow({ children:[new TableCell({
    borders:noBord, shading:{fill:bg, type:ShadingType.CLEAR},
    margins:{top:120, bottom:120, left:180, right:180},
    children:[new Paragraph({ spacing:sp(0,0), children:[
      new TextRun({text:`${emoji}  `, size:22, font}),
      new TextRun({text, size:22, color:col, font}),
    ]})],
  })]})],
});

const band = (emoji, title, sub, bg=C.navy) => new Table({
  width:{size:9360, type:WidthType.DXA}, columnWidths:[9360],
  rows:[new TableRow({ children:[new TableCell({
    borders:noBord, shading:{fill:bg, type:ShadingType.CLEAR},
    margins:{top:180, bottom:180, left:240, right:240},
    children:[
      new Paragraph({spacing:sp(0,60), children:[new TextRun({text:`${emoji}  ${title}`, bold:true, size:32, color:C.white, font})]}),
      new Paragraph({spacing:sp(0,0), children:[new TextRun({text:sub, size:20, color:'C7D2FE', font})]}),
    ],
  })]})],
});

const badges = items => {
  const w = Math.floor(9360/items.length);
  return new Table({
    width:{size:9360, type:WidthType.DXA},
    columnWidths:items.map(()=>w),
    rows:[new TableRow({ children:items.map(({label,color,bg})=>new TableCell({
      borders:noBord, shading:{fill:bg, type:ShadingType.CLEAR},
      margins:{top:80, bottom:80, left:120, right:120},
      children:[new Paragraph({ alignment:AlignmentType.CENTER,
        children:[new TextRun({text:label, bold:true, size:20, color, font})] })],
    }))})],
  });
};

const testTable = rows => new Table({
  width:{size:9360, type:WidthType.DXA},
  columnWidths:[620, 3200, 5540],
  rows:[
    new TableRow({ children:[
      new TableCell({ borders:bord, shading:{fill:C.purple, type:ShadingType.CLEAR}, margins:{top:100,bottom:100,left:100,right:100},
        children:[new Paragraph({children:[new TextRun({text:'#', bold:true, size:20, color:C.white, font})]})] }),
      new TableCell({ borders:bord, shading:{fill:C.purple, type:ShadingType.CLEAR}, margins:{top:100,bottom:100,left:120,right:120},
        children:[new Paragraph({children:[new TextRun({text:'What to do', bold:true, size:20, color:C.white, font})]})] }),
      new TableCell({ borders:bord, shading:{fill:C.purple, type:ShadingType.CLEAR}, margins:{top:100,bottom:100,left:120,right:120},
        children:[new Paragraph({children:[new TextRun({text:'What you should see ✅', bold:true, size:20, color:C.white, font})]})] }),
    ]}),
    ...rows.map((row,i) => new TableRow({ children:[
      new TableCell({ borders:bord, shading:{fill:i%2===0?C.white:C.grayBg, type:ShadingType.CLEAR}, margins:{top:80,bottom:80,left:100,right:100},
        children:[new Paragraph({alignment:AlignmentType.CENTER, children:[new TextRun({text:String(row[0]), bold:true, size:20, color:C.purple, font})]})] }),
      new TableCell({ borders:bord, shading:{fill:i%2===0?C.white:C.grayBg, type:ShadingType.CLEAR}, margins:{top:80,bottom:80,left:120,right:120},
        children:[new Paragraph({children:[new TextRun({text:row[1], bold:true, size:20, color:C.gray, font})]})] }),
      new TableCell({ borders:bord, shading:{fill:i%2===0?C.white:C.grayBg, type:ShadingType.CLEAR}, margins:{top:80,bottom:80,left:120,right:120},
        children:[new Paragraph({children:[new TextRun({text:row[2], size:20, color:C.gray, font})]})] }),
    ]})),
  ],
});

// ── Build document ─────────────────────────────────────────
const doc = new Document({
  numbering:{ config:[
    { reference:'bullets', levels:[
      {level:0, format:LevelFormat.BULLET, text:'•', alignment:AlignmentType.LEFT, style:{paragraph:{indent:{left:720,hanging:360}}}},
      {level:1, format:LevelFormat.BULLET, text:'◦', alignment:AlignmentType.LEFT, style:{paragraph:{indent:{left:1080,hanging:360}}}},
    ]},
  ]},
  styles:{
    default:{ document:{ run:{font:'Arial', size:22} } },
    paragraphStyles:[
      {id:'Heading1',name:'Heading 1',basedOn:'Normal',next:'Normal',quickFormat:true,
        run:{size:36,bold:true,font,color:C.navy}, paragraph:{spacing:sp(360,160),outlineLevel:0}},
      {id:'Heading2',name:'Heading 2',basedOn:'Normal',next:'Normal',quickFormat:true,
        run:{size:28,bold:true,font,color:C.purple}, paragraph:{spacing:sp(280,120),outlineLevel:1}},
      {id:'Heading3',name:'Heading 3',basedOn:'Normal',next:'Normal',quickFormat:true,
        run:{size:24,bold:true,font,color:C.navy}, paragraph:{spacing:sp(200,80),outlineLevel:2}},
    ],
  },
  sections:[{
    properties:{ page:{ size:{width:12240,height:15840}, margin:{top:1080,right:1080,bottom:1080,left:1080} } },
    footers:{ default:new Footer({ children:[new Paragraph({
      alignment:AlignmentType.CENTER,
      children:[new TextRun({text:'StatusVault Complete Test Guide  •  statusvault.org', size:18, color:'9CA3AF', font})],
    })] }) },
    children:[

    // ── COVER ──────────────────────────────────────────────
    band('🛡️', 'StatusVault — Complete Testing Guide', 'All features · All user types · All edge cases  •  statusvault.org'),


    ...spaces(2),
    badges([
      {label:'👤  GUEST MODE  (No account)', color:C.amber, bg:C.amberBg},
      {label:'🔓  FREE ACCOUNT', color:C.blue, bg:C.blueBg},
      {label:'⭐  PREMIUM ACCOUNT', color:C.green, bg:C.greenBg},
    ]),
    ...spaces(1),
    note('📌', 'HOW TO USE THIS GUIDE: Work through each section in order. Every test case has a step number and tells you exactly what you should see. If the app does something different — that is a bug. Write it down using the template at the end.'),
    ...spaces(1),
    note('💻', 'SETUP: Open Chrome or Edge on your laptop. Go to https://www.statusvault.org. Use a fresh private/incognito window for each section so old sessions do not interfere.', C.greenBg, C.green),
    ...spaces(2),
    divider(),

    // ════════════════════════════════════════════════════════
    // SECTION 1 — GUEST MODE
    // ════════════════════════════════════════════════════════
    ...spaces(1),
    band('👤', 'SECTION 1 — GUEST MODE', 'No account · 1 doc · 1 checklist · 1 timer · no family'),
    ...spaces(1),
    body('Guest Mode is a try-before-you-sign-up experience. No email required. Everything is saved on your device. You get one of each major feature to try.'),
    ...spaces(1),

    h3('TC-G-01  First visit — Welcome Screen'),
    testTable([
      [1,'Open statusvault.org in incognito window','A welcome modal pops up with two buttons: "Continue as Guest" and "Create Free Account"'],
      [2,'Read the Guest section carefully','Shows exactly: 1 document · 1 checklist · 1 timer · No family'],
      [3,'Click "Continue as Guest"','Welcome modal closes. You land on the Dashboard.'],
      [4,'Look at the top bar or sidebar','It says "Guest mode" — NOT your name. No PRO or FREE badge.'],
      [5,'Look at bottom of dashboard','A small green pill: "Saving to device..." or "Saved to device Just now"'],
    ]),
    ...spaces(1),

    h3('TC-G-02  Immigration Profile Setup (appears once after Guest selection)'),
    note('ℹ️', 'After selecting Guest mode for the first time, a Profile Setup screen may appear. This is optional — you can skip it or fill it in. It personalises the dashboard.'),
    ...spaces(1),
    testTable([
      [1,'After the welcome modal closes, watch for a profile setup screen','A multi-step form may slide in: Personal Info, Visa & Work, Green Card'],
