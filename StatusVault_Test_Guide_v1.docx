    new Table({
      width:{size:9360, type:WidthType.DXA},
      columnWidths:[2400, 6960],
      rows:[
        ...['Test Case ID|e.g. TC-E-03 Step 2',
            'User Type|e.g. Premium account (PRO badge visible)',
            'What I did|e.g. Added a trip with return date before departure date',
            'What I expected|e.g. An error message — trip should not save',
            'What actually happened|e.g. Trip saved with negative days (-5 shown on card)',
            'How to reproduce|e.g. 1. Go to Travel tab  2. Click Add Trip  3. Set return = 2024-01-01, departure = 2024-01-10  4. Click Save',
            'Browser & OS|e.g. Chrome 124, Windows 11',
            'Screenshot?|e.g. Attached / Not taken',
        ].map((row, i) => {
          const [label, example] = row.split('|');
          return new TableRow({ children:[
            new TableCell({ borders:bord, shading:{fill:i===0?C.purple:C.grayBg, type:ShadingType.CLEAR}, margins:{top:100,bottom:100,left:140,right:140},
              children:[new Paragraph({children:[new TextRun({text:label, bold:true, size:20, color:i===0?C.white:C.navy, font})]})] }),
            new TableCell({ borders:bord, shading:{fill:i===0?C.purple:C.white, type:ShadingType.CLEAR}, margins:{top:100,bottom:100,left:140,right:140},
              children:[new Paragraph({children:[new TextRun({text:example, size:20, color:i===0?C.white:C.gray, font, italics:i>0})]})] }),
          ]});
        }),
      ],
    }),

    ...spaces(2),
    note('✅', 'TESTING COMPLETE! You have covered: Guest Mode (11 tests) · Free Account (11 tests) · Premium (8 tests) · Account Management (3 tests) · Edge Cases & Grey Scenarios (11 tests) = 44 test cases total covering every feature in StatusVault.', C.greenBg, C.green),

  ]}],
});

Packer.toBuffer(doc).then(buf => {
  fs.writeFileSync('/mnt/user-data/outputs/StatusVault_Test_Guide.docx', buf);
  console.log('Done:', Math.round(buf.length/1024), 'KB');
});
